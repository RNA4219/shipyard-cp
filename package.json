{
  "name": "shipyard-cp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI worker orchestration control plane scaffold",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "npm run build:packages && tsc -p tsconfig.json",
    "build:packages": "npm run build -w shared-redis-utils && npm run build -w memx-resolver-js && npm run build -w tracker-bridge-js && npm run build -w agent-taskstate-js",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src packages",
    "lint:fix": "eslint src packages --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "agent-taskstate-js": "workspace:*",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.10.0",
    "memx-resolver-js": "workspace:*",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "tracker-bridge-js": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.13.14",
    "@types/pino": "^7.0.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0",
    "ws": "^8.19.0"
  }
}