    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  }
}
