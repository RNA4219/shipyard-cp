{
  "name": "shipyard-cp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI worker orchestration control plane scaffold",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
