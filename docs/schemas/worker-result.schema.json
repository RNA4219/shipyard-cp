{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipyard-cp.local/schemas/worker-result.schema.json",
  "title": "WorkerResult",
  "description": "ワーカー実行完了後に Control Plane へ返却・保存する正規化済み結果契約。agent-taskstate / memx-resolver / tracker-bridge-materials 連携に必要な参照も保持する。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "typed_ref",
    "status",
    "artifacts",
    "test_results",
    "requested_escalations",
    "usage"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "typed_ref": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[a-z0-9_-]+:.+$",
      "description": "agent-taskstate / tracker-bridge-materials に整合する canonical typed_ref。"
    },
    "status": { "type": "string", "enum": ["succeeded", "failed", "blocked"] },
    "summary": { "type": "string" },
    "patch_ref": { "$ref": "#/$defs/patchRef" },
    "branch_ref": { "$ref": "#/$defs/branchRef" },
    "artifacts": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "test_results": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/testResult" }
    },
    "verdict": { "$ref": "#/$defs/verdict" },
    "requested_escalations": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/requestedEscalation" }
    },
    "usage": { "$ref": "#/$defs/usage" },
    "resolver_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "doc_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "chunk_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "ack_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "contract_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "stale_status": { "type": "string", "enum": ["fresh", "stale", "unknown"] }
      }
    },
    "external_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/externalRef" }
    },
    "context_bundle_ref": {
      "type": "string",
      "description": "agent-taskstate context bundle 参照。"
    },
    "rollback_notes": {
      "type": "string",
      "description": "高リスク Acceptance で残すロールバック観点メモ。"
    },
    "raw_outputs": {
      "type": "array",
      "description": "ワーカー固有の生出力参照。",
      "items": { "$ref": "#/$defs/rawOutput" }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "succeeded" } },
        "required": ["status"]
      },
      "then": {
        "anyOf": [
          { "required": ["patch_ref"] },
          { "required": ["branch_ref"] },
          { "required": ["verdict"] },
          { "properties": { "artifacts": { "minItems": 1 } }, "required": ["artifacts"] }
        ]
      }
    }
  ],
  "$defs": {
    "patchRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "content"],
      "properties": {
        "format": { "type": "string", "enum": ["unified_diff", "git_apply_patch", "url"] },
        "content": { "type": "string", "minLength": 1 },
        "base_sha": { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" }
      }
    },
    "branchRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "head_sha": { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" },
        "remote_url": { "type": "string", "format": "uri" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "kind", "uri"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["log", "screenshot", "report", "trace", "json", "html", "other"] },
        "uri": { "type": "string", "minLength": 1 },
        "content_type": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "description": { "type": "string" }
      }
    },
    "testResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suite", "status"],
      "properties": {
        "suite": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["passed", "failed", "skipped", "not_run"] },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "artifact_id": { "type": "string" }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome"],
      "properties": {
        "outcome": { "type": "string", "enum": ["accept", "reject", "rework", "needs_manual_review"] },
        "reason": { "type": "string" },
        "checklist_completed": { "type": "boolean" },
        "manual_notes": { "type": "string" }
      }
    },
    "requestedEscalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reason"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "network_access",
            "workspace_outside_write",
            "protected_path_write",
            "destructive_tool",
            "secret_access",
            "human_verdict"
          ]
        },
        "reason": { "type": "string", "minLength": 1 },
        "approved": { "type": "boolean" }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_ms"],
      "properties": {
        "runtime_ms": { "type": "integer", "minimum": 0 },
        "exit_code": { "type": "integer" },
        "litellm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string" },
            "provider": { "type": "string" },
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "cost_usd": { "type": "number", "minimum": 0 },
            "fallback_used": { "type": "boolean" }
          }
        }
      }
    },
    "rawOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel", "artifact_id"],
      "properties": {
        "channel": { "type": "string", "enum": ["stdout", "stderr", "json", "event_stream"] },
        "artifact_id": { "type": "string", "minLength": 1 }
      }
    },
    "externalRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["github_issue", "github_project_item", "release", "deployment", "tag", "tracker_issue", "sync_event", "entity_link"] },
        "value": { "type": "string", "minLength": 1 },
        "connection_ref": { "type": "string" }
      }
    }
  },
  "examples": [
    {
      "job_id": "job_01JPC1J3X2W1W7M0K9A2D8QF8P",
      "typed_ref": "shipyard:task:github:01JPC1GY8JQ7YQ8MS9D7Q0B8QA",
      "status": "succeeded",
      "summary": "Schema ファイルを追加し、検証ログを生成した。",
      "artifacts": [
        {
          "artifact_id": "art_01JPC1QFJ9J7YBKWT3YTT0Z8ZR",
          "kind": "log",
          "uri": "artifact://logs/dev-run.log",
          "content_type": "text/plain"
        }
      ],
      "test_results": [
        {
          "suite": "unit",
          "status": "passed",
          "passed": 12,
          "failed": 0,
          "skipped": 0,
          "duration_ms": 4810,
          "artifact_id": "art_01JPC1QFJ9J7YBKWT3YTT0Z8ZR"
        }
      ],
      "resolver_refs": {
        "doc_refs": ["workflow-cookbook:blueprint"],
        "chunk_refs": ["chunk:workflow-cookbook:blueprint:1"],
        "ack_refs": ["ack:task_01JPC1GY8JQ7YQ8MS9D7Q0B8QA:workflow-cookbook:blueprint:v1"],
        "contract_refs": ["contract:resolver"],
        "stale_status": "fresh"
      },
      "external_refs": [
        {
          "kind": "github_project_item",
          "value": "PVT_item_123"
        },
        {
          "kind": "sync_event",
          "value": "sync_evt_456"
        }
      ],
      "context_bundle_ref": "bundle:task_01JPC1GY8JQ7YQ8MS9D7Q0B8QA:v3",
      "requested_escalations": [],
      "usage": {
        "runtime_ms": 18642,
        "exit_code": 0,
        "litellm": {
          "model": "gpt-5.4",
          "provider": "openai",
          "input_tokens": 1422,
          "output_tokens": 611,
          "cost_usd": 0.0421,
          "fallback_used": false
        }
      },
      "raw_outputs": [
        {
          "channel": "stdout",
          "artifact_id": "art_01JPC1QFJ9J7YBKWT3YTT0Z8ZR"
        }
      ]
    }
  ]
}
