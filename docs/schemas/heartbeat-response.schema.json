{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipyard-cp.local/schemas/heartbeat-response.schema.json",
  "title": "HeartbeatResponse",
  "description": "heartbeat 受理後に返す lease 更新結果。",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_id", "lease_expires_at", "next_heartbeat_due_at"],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "lease_expires_at": { "type": "string", "format": "date-time" },
    "next_heartbeat_due_at": { "type": "string", "format": "date-time" }
  }
}
