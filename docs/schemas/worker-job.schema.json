{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipyard-cp.local/schemas/worker-job.schema.json",
  "title": "WorkerJob",
  "description": "Control Plane からワーカーへ投入する正規化済みジョブ契約。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "task_id",
    "stage",
    "worker_type",
    "workspace_ref",
    "input_prompt",
    "repo_ref",
    "capability_requirements",
    "risk_level",
    "approval_policy",
    "typed_ref"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "typed_ref": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[a-z0-9_-]+:.+$"
    },
    "stage": {
      "type": "string",
      "enum": ["plan", "dev", "acceptance"],
      "description": "担当工程。Integrate / Publish はワーカー工程ではないため含めない。"
    },
    "worker_type": {
      "type": "string",
      "enum": ["codex", "claude_code", "google_antigravity"],
      "description": "実行対象ワーカー種別。"
    },
    "workspace_ref": { "$ref": "#/$defs/workspaceRef" },
    "input_prompt": {
      "type": "string",
      "minLength": 1,
      "description": "ワーカーへ渡す主プロンプト。Skill 専用フィールドは持たず、追加ガイダンスもここや context.references / constraints に展開する。"
    },
    "repo_ref": { "$ref": "#/$defs/repoRef" },
    "capability_requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability" },
      "minItems": 1,
      "uniqueItems": true
    },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "approval_policy": { "$ref": "#/$defs/approvalPolicy" },
    "retry_policy": { "$ref": "#/$defs/retryPolicy" },
    "retry_count": { "type": "integer", "minimum": 0 },
    "loop_fingerprint": { "type": "string", "minLength": 1 },
    "lease_owner": { "type": "string", "minLength": 1 },
    "lease_expires_at": { "type": "string", "format": "date-time" },
    "context": {
      "type": "object",
      "description": "タスク文脈の付帯情報。",
      "additionalProperties": true,
      "properties": {
        "objective": { "type": "string" },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "references": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolver_refs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "doc_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
            "chunk_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
            "contract_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
          }
        },
        "tracker_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference" }
        }
      }
    },
    "requested_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["patch", "branch", "tests", "verdict", "artifacts", "plan_notes", "resolver_refs"]
      },
      "uniqueItems": true
    },
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "queue_timeout_sec": { "type": "integer", "minimum": 1 },
        "run_timeout_sec": { "type": "integer", "minimum": 1 }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "string",
      "enum": [
        "plan",
        "edit_repo",
        "run_tests",
        "needs_approval",
        "networked",
        "produces_patch",
        "produces_verdict"
      ]
    },
    "workspaceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "kind"],
      "properties": {
        "workspace_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["container", "volume", "host_path"] },
        "container_image": { "type": "string" },
        "mount_path": { "type": "string" },
        "reusable": { "type": "boolean" }
      }
    },
    "repoRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "owner", "name", "default_branch"],
      "properties": {
        "provider": { "type": "string", "enum": ["github"] },
        "owner": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "default_branch": { "type": "string", "minLength": 1 },
        "clone_url": { "type": "string", "format": "uri" },
        "base_sha": { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" },
        "integration_branch": { "type": "string" }
      }
    },
    "approvalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["deny", "ask", "allow"] },
        "allowed_side_effect_categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "network_access",
              "workspace_outside_write",
              "protected_path_write",
              "destructive_tool",
              "external_release",
              "secret_access"
            ]
          },
          "uniqueItems": true
        },
        "operator_approval_required": { "type": "boolean" },
        "sandbox_profile": { "type": "string", "enum": ["read_only", "workspace_write", "full_auto", "custom"] }
      }
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_retries"],
      "properties": {
        "max_retries": { "type": "integer", "minimum": 0 },
        "backoff_base_seconds": { "type": "integer", "minimum": 1 },
        "max_backoff_seconds": { "type": "integer", "minimum": 1 },
        "jitter_enabled": { "type": "boolean" }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["url", "file", "issue", "commit", "doc", "typed_ref"] },
        "value": { "type": "string", "minLength": 1 },
        "label": { "type": "string" }
      }
    }
  },
  "examples": [
    {
      "job_id": "job_01JPC1J3X2W1W7M0K9A2D8QF8P",
      "task_id": "task_01JPC1GY8JQ7YQ8MS9D7Q0B8QA",
      "typed_ref": "agent-taskstate:task:github:01JPC1GY8JQ7YQ8MS9D7Q0B8QA",
      "stage": "dev",
      "worker_type": "codex",
      "workspace_ref": {
        "workspace_id": "ws_01JPC1JY4S4Y7X7Y4M7XWZ0G3S",
        "kind": "container",
        "container_image": "ghcr.io/example/devbox:latest",
        "mount_path": "/workspace",
        "reusable": true
      },
      "input_prompt": "REQUIREMENTS.md に沿って schema 生成を実装する。",
      "repo_ref": {
        "provider": "github",
        "owner": "example",
        "name": "shipyard-cp",
        "default_branch": "main",
        "base_sha": "8f53b9ae6d2f1a7c9f1c330e4c56d9b462d1e31b",
        "integration_branch": "cp/integrate/task_01JPC1GY8JQ7YQ8MS9D7Q0B8QA"
      },
      "capability_requirements": ["edit_repo", "run_tests", "produces_patch"],
      "risk_level": "medium",
      "retry_policy": {
        "max_retries": 3,
        "backoff_base_seconds": 5,
        "max_backoff_seconds": 60,
        "jitter_enabled": true
      },
      "retry_count": 0,
      "loop_fingerprint": "sha256:8f1d2db0d3fd1c7d",
      "approval_policy": {
        "mode": "ask",
        "allowed_side_effect_categories": ["network_access"],
        "operator_approval_required": true,
        "sandbox_profile": "workspace_write"
      },
      "requested_outputs": ["patch", "tests", "artifacts", "resolver_refs"]
    }
  ]
}
