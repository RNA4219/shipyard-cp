# Frontend Environment Variables
# Copy this file to .env.local for local development

# API Backend Host (used by Vite proxy)
VITE_API_HOST=http://localhost:3100

# WebSocket Host (used by Vite proxy)
VITE_WS_HOST=ws://localhost:3100

# Frontend Server Port (default: 5273)
VITE_PORT=5273

# E2E Test Configuration
# Backend URL for E2E tests (health checks)
E2E_BACKEND_URL=http://localhost:3100
# Frontend URL for E2E tests
E2E_FRONTEND_URL=http://localhost:5273