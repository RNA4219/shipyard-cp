# shipyard-cp Environment Configuration
# Copy this file to .env and configure as needed

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# External Services
# =============================================================================
# memx-resolver - Document resolver service
MEMX_RESOLVER_URL=http://localhost:8080

# tracker-bridge - Tracker integration service
TRACKER_BRIDGE_URL=http://localhost:8081

# =============================================================================
# API Keys (required for actual usage)
# =============================================================================

# GitHub Personal Access Token (for GitHub Projects, Issues, PRs)
# Required scopes: repo, project
GITHUB_TOKEN=

# OpenAI API Key (for Codex adapter)
OPENAI_API_KEY=

# Anthropic API Key (for Claude Code adapter)
ANTHROPIC_API_KEY=

# Google/Gemini API Key (for Antigravity adapter)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# Optional Configuration
# =============================================================================

# Google Cloud Project (for Antigravity adapter)
GOOGLE_CLOUD_PROJECT=

# Redis URL (for production caching)
REDIS_URL=redis://localhost:6379

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug logging for specific domains
DEBUG_SHIPYARD=