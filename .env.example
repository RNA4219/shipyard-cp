# shipyard-cp Environment Configuration
# Copy this file to .env and configure as needed

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3100
NODE_ENV=development

# =============================================================================
# Redis Configuration (Production Persistence)
# =============================================================================
# Redis URL for task/job/result/event storage
REDIS_URL=redis://localhost:6379
# Key prefix for namespace isolation
REDIS_KEY_PREFIX=shipyard-cp:

# TTL settings in seconds (optional, defaults shown)
# REDIS_TASK_TTL=604800        # 7 days
# REDIS_JOB_TTL=86400          # 24 hours
# REDIS_RESULT_TTL=86400       # 24 hours
# REDIS_EVENT_TTL=2592000      # 30 days

# =============================================================================
# External Services
# =============================================================================
# memx-resolver - Document resolver service
MEMX_RESOLVER_URL=http://localhost:8080

# tracker-bridge - Tracker integration service
TRACKER_BRIDGE_URL=http://localhost:8081

# =============================================================================
# API Keys (required for actual usage)
# =============================================================================

# GitHub Personal Access Token (for GitHub Projects, Issues, PRs)
# Required scopes: repo, project
GITHUB_TOKEN=

# OpenAI API Key (for Codex adapter)
OPENAI_API_KEY=

# Anthropic API Key (for Claude Code adapter)
ANTHROPIC_API_KEY=

# Google/Gemini API Key (for Antigravity adapter)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Alibaba Cloud / GLM API Key (for GLM-5 adapter)
# DASHSCOPE_API_KEY or GLM_API_KEY can be used
GLM_API_KEY=
DASHSCOPE_API_KEY=

# =============================================================================
# Worker Backends
# =============================================================================
# Logical worker -> backend selection
# CLAUDE_WORKER_BACKEND: opencode | glm | claude_cli | simulation
# CODEX_WORKER_BACKEND: opencode | simulation
CLAUDE_WORKER_BACKEND=opencode
CODEX_WORKER_BACKEND=opencode

# CLI paths
CLAUDE_CLI_PATH=claude
OPENCODE_CLI_PATH=opencode

# =============================================================================
# OpenCode Serve / Session Configuration (Phase 2A)
# =============================================================================
# Execution mode: run (default) or serve
OPENCODE_MODE=run

# Path for opencode serve (defaults to OPENCODE_CLI_PATH)
# OPENCODE_SERVE_PATH=opencode

# Base URL for opencode serve API
# OPENCODE_SERVE_BASE_URL=http://localhost:3001

# Session reuse policy: disabled (default) or same_stage
OPENCODE_SESSION_REUSE=disabled

# Session TTL in milliseconds (default: 1 hour)
# OPENCODE_SESSION_TTL_MS=3600000

# Server startup timeout in milliseconds (default: 30 seconds)
# OPENCODE_SERVER_STARTUP_TIMEOUT_MS=30000

# Reuse lease TTL in milliseconds (default: 5 minutes)
# OPENCODE_REUSE_LEASE_TTL_MS=300000

# =============================================================================
# Authentication (P1 - Production Required)
# =============================================================================
# API_KEY=your-api-key-here
# ADMIN_API_KEY=your-admin-api-key-here

# =============================================================================
# Optional Configuration
# =============================================================================

# Google Cloud Project (for Antigravity adapter)
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug logging for specific domains
DEBUG_SHIPYARD=

# Monitoring
# SENTRY_DSN=https://xxx@sentry.io/xxx
